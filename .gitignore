# Terraform local state and caches
**/.terraform/
**/*.tfstate
**/*.tfstate.*
**/crash.log
**/crash.*.log
**/override.tf
**/override.tf.json
**/*_override.tf
**/*_override.tf.json

# Terraform variable files that commonly hold secrets
**/*.tfvars
**/*.tfvars.json

# Keep shareable Terraform examples
!**/*.tfvars.example

# Local plan outputs
**/*.tfplan
**/plan.out

# OCI and SSH private keys
**/*.pem
**/*.key
**/id_rsa
**/id_ed25519
**/.oci/

# Optional local env files
**/.env
**/.env.*
!**/.env.example

# Local deploy env file generated by CI helper steps
infra/deploy/backend/.deploy.env

# Local Gradle cache used in this workspace
.gradle-local/
