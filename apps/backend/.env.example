# AI Provider
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key

# OAuth: use a development client registered in Google Cloud Console.
# Authorized redirect URI: http://localhost:8080/api/auth/callback/google
GOOGLE_CLIENT_ID=google-client-id
GOOGLE_CLIENT_SECRET=google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/callback/google

# JWT
JWT_SECRET=this-is-a-development-secret-key-at-least-32-bytes-long!!
